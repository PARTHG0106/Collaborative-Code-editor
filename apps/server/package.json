    "socket.io": "^4.8.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@collab/eslint-config": "*",
    "@collab/typescript-config": "*",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^8.0.1",
    "@types/supertest": "^6.0.2",
    "eslint": "^8.57.0",
    "prisma": "^5.20.0",
    "rimraf": "^6.0.1",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
