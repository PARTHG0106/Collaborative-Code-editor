// Prisma schema for Collaborative Code Editor
// This schema will grow as we add features in each phase

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Tracks database health and migration status
model HealthCheck {
  id        String   @id @default(cuid())
  status    String   @default("ok")
  checkedAt DateTime @default(now()) @map("checked_at")

  @@map("health_checks")
}

model User {
  id            String            @id @default(cuid())
  email         String            @unique
  passwordHash  String            @map("password_hash")
  name          String
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")
  isVerified          Boolean           @default(false) @map("is_verified")
  verificationToken   String?           @map("verification_token")
  verificationExpires DateTime?         @map("verification_expires")
  refreshTokens       RefreshToken[]
  workspaces          WorkspaceMember[]
  chatMessages        ChatMessage[]
  fileVersions        FileVersion[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("refresh_tokens")
}

enum WorkspaceRole {
  OWNER
  EDITOR
  VIEWER
}

model Workspace {
  id              String            @id @default(cuid())
  name            String
  description     String?
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  members         WorkspaceMember[]
  fileSystemItems FileSystemItem[]
  chatMessages    ChatMessage[]

  @@map("workspaces")
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String        @map("workspace_id")
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String        @map("user_id")
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        WorkspaceRole @default(VIEWER)
  joinedAt    DateTime      @default(now()) @map("joined_at")

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

enum FileSystemItemType {
  FILE
  FOLDER
}

model FileSystemItem {
  id          String             @id @default(cuid())
  name        String
  type        FileSystemItemType
  content     String?            // Null for folders, text for files
  parentId    String?            @map("parent_id")
  parent      FileSystemItem?    @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children    FileSystemItem[]   @relation("FolderHierarchy")
  workspaceId String             @map("workspace_id")
  workspace   Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")
  versions    FileVersion[]

  @@unique([workspaceId, parentId, name])
  @@map("file_system_items")
}

model ChatMessage {
  id          String    @id @default(cuid())
  workspaceId String    @map("workspace_id")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String    @map("user_id")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  message     String
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("chat_messages")
}

model FileVersion {
  id        String         @id @default(cuid())
  fileId    String         @map("file_id")
  file      FileSystemItem @relation(fields: [fileId], references: [id], onDelete: Cascade)
  content   String
  version   Int
  userId    String?        @map("user_id")
  user      User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime       @default(now()) @map("created_at")

  @@map("file_versions")
}
